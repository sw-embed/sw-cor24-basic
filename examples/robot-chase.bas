103 REM
104 REM 9X9 TURN-BASED ROBOT CHASE. ROBOTS STEP ONE
105 REM SQUARE TOWARD YOU EACH TURN. MAKE THEM COLLIDE
106 REM INTO EACH OTHER OR INTO WRECKAGE. CLEAR ALL
107 REM ROBOTS TO WIN. TOUCH A ROBOT OR A WRECK AND LOSE.
108 REM
109 REM COMMANDS (KEYPAD):
110 REM   7 8 9     7=NW  8=N  9=NE
111 REM   4 5 6     4=W   5=WAIT  6=E
112 REM   1 2 3     1=SW  2=S  3=SE
113 REM   0=TELEPORT (2 PER GAME)
114 REM   10=LRS (3X3 REGIONAL SUMMARY)
115 REM   99=RESIGN
116 REM
117 REM MEMORY:
118 REM   0..80    BOARD CELL  (0=EMPTY 2=ROBOT 3=WRECK)
119 REM   100..107 ROBOT X (0..8)
120 REM   108..115 ROBOT Y
121 REM   116..123 ROBOT ALIVE (0/1)
122 REM
123 REM VARS:
124 REM   A,B   PLAYER X,Y
125 REM   N     ROBOT COUNT (TOTAL)
126 REM   T     TELEPORTS LEFT
127 REM   U     TURN NUMBER
128 REM   L     ALIVE ROBOT COUNT
129 REM   G,W   GAMEOVER, WIN FLAGS
130 REM   R     PRNG STATE
131 REM   C     COMMAND
132 REM   I,J   LOOPS
133 REM   X,Y   SCRATCH COORDS
134 REM   S,D,E SCRATCH
135 REM   F,H   LRS REGION ORIGIN
136 REM   K,M,O LRS COUNTS (R/W/P)
137 REM
138 PRINT
139 PRINT "*** ROBOT CHASE ***"
140 PRINT "EVADE THE ROBOTS - MAKE THEM COLLIDE."
141 PRINT
142 LET R=5237
143 LET N=8
144 LET T=2
145 LET U=0
146 LET G=0
147 LET W=0
148 GOSUB 1000
199 REM ---- MAIN LOOP ----
200 GOSUB 1500
201 IF L=0 THEN LET W=1
202 IF L=0 THEN LET G=1
203 IF G=1 THEN GOTO 9500
204 LET U=U+1
205 GOSUB 2000
210 GOSUB 3000
211 IF C=99 THEN GOTO 9800
212 IF C=10 THEN GOSUB 7000
213 IF C=10 THEN GOTO 205
220 GOSUB 4000
221 IF G=1 THEN GOTO 9500
222 GOSUB 5000
223 IF G=1 THEN GOTO 9500
230 GOTO 200
998 REM
999 REM ---- INIT: CLEAR BOARD, PLACE PLAYER AND ROBOTS ----
1000 FOR I=0 TO 80
1001 POKE I,0
1002 NEXT I
1010 GOSUB 6000
1011 LET A=R-(R/9)*9
1020 GOSUB 6000
1021 LET B=R-(R/9)*9
1030 FOR I=0 TO N-1
1040 GOSUB 1100
1050 NEXT I
1060 RETURN
1098 REM
1099 REM ---- PLACE ROBOT I AT A RANDOM EMPTY, NON-PLAYER CELL ----
1100 GOSUB 6000
1101 LET X=R-(R/9)*9
1110 GOSUB 6000
1111 LET Y=R-(R/9)*9
1120 IF X=A AND Y=B THEN GOTO 1100
1130 LET S=Y*9+X
1131 IF PEEK(S)<>0 THEN GOTO 1100
1140 POKE S,2
1141 POKE 100+I,X
1142 POKE 108+I,Y
1143 POKE 116+I,1
1150 RETURN
1498 REM
1499 REM ---- COUNT ALIVE ROBOTS INTO L ----
1500 LET L=0
1510 FOR I=0 TO N-1
1511 IF PEEK(116+I)=1 THEN LET L=L+1
1520 NEXT I
1530 RETURN
1998 REM
1999 REM ---- RENDER: HEADER + 9X9 BOARD ----
2000 PRINT
2001 PRINT "TURN ";U;"   ROBOTS ";L;"   TELE ";T
2002 PRINT "  0 1 2 3 4 5 6 7 8"
2010 FOR Y=0 TO 8
2011 PRINT Y;" ";
2020 FOR X=0 TO 8
2021 GOSUB 2100
2022 NEXT X
2023 PRINT
2024 NEXT Y
2025 RETURN
2098 REM
2099 REM ---- PRINT ONE CELL (X,Y) AS "C " ----
2100 IF X=A AND Y=B THEN PRINT "P ";
2101 IF X=A AND Y=B THEN RETURN
2110 LET S=Y*9+X
2111 LET D=PEEK(S)
2112 IF D=0 THEN PRINT ". ";
2113 IF D=2 THEN PRINT "R ";
2114 IF D=3 THEN PRINT "* ";
2115 RETURN
2998 REM
2999 REM ---- READ COMMAND INTO C ----
3000 PRINT
3001 PRINT "1-9=MOVE(5=WAIT) 0=TELE 10=LRS 99=QUIT"
3010 INPUT "COMMAND ";C
3020 RETURN
3998 REM
3999 REM ---- MOVE PLAYER ----
4000 LET X=A
4001 LET Y=B
4010 IF C=1 THEN LET X=A-1
4011 IF C=1 THEN LET Y=B+1
4020 IF C=2 THEN LET Y=B+1
4030 IF C=3 THEN LET X=A+1
4031 IF C=3 THEN LET Y=B+1
4040 IF C=4 THEN LET X=A-1
4060 IF C=6 THEN LET X=A+1
4070 IF C=7 THEN LET X=A-1
4071 IF C=7 THEN LET Y=B-1
4080 IF C=8 THEN LET Y=B-1
4090 IF C=9 THEN LET X=A+1
4091 IF C=9 THEN LET Y=B-1
4100 IF C=0 THEN GOSUB 4300
4101 IF C=0 THEN RETURN
4110 IF X<0 THEN PRINT "BLOCKED BY WALL."
4111 IF X<0 THEN RETURN
4112 IF Y<0 THEN PRINT "BLOCKED BY WALL."
4113 IF Y<0 THEN RETURN
4114 IF X>8 THEN PRINT "BLOCKED BY WALL."
4115 IF X>8 THEN RETURN
4116 IF Y>8 THEN PRINT "BLOCKED BY WALL."
4117 IF Y>8 THEN RETURN
4120 LET S=Y*9+X
4121 LET D=PEEK(S)
4122 IF D=3 THEN PRINT "YOU STEPPED ONTO WRECKAGE."
4123 IF D=3 THEN LET G=1
4124 IF D=3 THEN RETURN
4125 IF D=2 THEN PRINT "YOU WALKED INTO A ROBOT."
4126 IF D=2 THEN LET G=1
4127 IF D=2 THEN RETURN
4130 LET A=X
4131 LET B=Y
4140 RETURN
4298 REM
4299 REM ---- TELEPORT ----
4300 IF T<=0 THEN PRINT "NO TELEPORTS LEFT."
4301 IF T<=0 THEN RETURN
4310 LET T=T-1
4320 GOSUB 6000
4321 LET A=R-(R/9)*9
4330 GOSUB 6000
4331 LET B=R-(R/9)*9
4340 LET S=B*9+A
4341 LET D=PEEK(S)
4342 IF D=3 THEN PRINT "TELEPORTED INTO WRECKAGE!"
4343 IF D=3 THEN LET G=1
4344 IF D=3 THEN RETURN
4350 IF D=2 THEN PRINT "TELEPORTED INTO A ROBOT!"
4351 IF D=2 THEN LET G=1
4352 IF D=2 THEN RETURN
4360 PRINT "*BEEP* TELEPORTED."
4370 RETURN
4998 REM
4999 REM ---- MOVE ROBOTS ONE STEP TOWARD PLAYER ----
5000 REM clear live-robot cells; wrecks remain
5010 FOR I=0 TO 80
5020 IF PEEK(I)=2 THEN POKE I,0
5030 NEXT I
5040 REM step each alive robot toward (A,B)
5050 FOR I=0 TO N-1
5060 IF PEEK(116+I)=0 THEN GOTO 5110
5070 LET X=PEEK(100+I)
5071 LET Y=PEEK(108+I)
5080 IF X<A THEN LET X=X+1
5081 IF X>A THEN LET X=X-1
5082 IF Y<B THEN LET Y=Y+1
5083 IF Y>B THEN LET Y=Y-1
5090 POKE 100+I,X
5091 POKE 108+I,Y
5092 IF X=A AND Y=B THEN LET G=1
5110 NEXT I
5114 IF G=1 THEN GOSUB 5400
5115 IF G=1 THEN PRINT "A ROBOT CAUGHT YOU!"
5116 IF G=1 THEN RETURN
5120 REM robot on wreck -> robot dies
5130 FOR I=0 TO N-1
5140 IF PEEK(116+I)=0 THEN GOTO 5180
5150 LET X=PEEK(100+I)
5151 LET Y=PEEK(108+I)
5160 LET S=Y*9+X
5170 IF PEEK(S)=3 THEN POKE 116+I,0
5180 NEXT I
5190 REM robot-robot collision -> both die, wreck created
5200 FOR I=0 TO N-1
5210 IF PEEK(116+I)=0 THEN GOTO 5290
5220 FOR J=I+1 TO N-1
5230 IF PEEK(116+J)=0 THEN GOTO 5280
5240 LET X=PEEK(100+I)
5241 LET Y=PEEK(108+I)
5242 LET D=PEEK(100+J)
5243 LET E=PEEK(108+J)
5250 IF X<>D THEN GOTO 5280
5251 IF Y<>E THEN GOTO 5280
5252 POKE 116+I,0
5253 POKE 116+J,0
5254 LET S=Y*9+X
5255 POKE S,3
5280 NEXT J
5290 NEXT I
5300 GOSUB 5400
5370 RETURN
5398 REM
5399 REM ---- PAINT SURVIVING ROBOTS ONTO BOARD ----
5400 FOR I=0 TO N-1
5410 IF PEEK(116+I)=0 THEN GOTO 5440
5420 LET X=PEEK(100+I)
5421 LET Y=PEEK(108+I)
5430 LET S=Y*9+X
5431 IF PEEK(S)=0 THEN POKE S,2
5440 NEXT I
5450 RETURN
5998 REM
5999 REM ---- PRNG: R = (R*97+1) MOD 8191 ----
6000 IF R<=0 THEN LET R=1
6001 LET R=R*97+1
6002 LET R=R-(R/8191)*8191
6003 RETURN
6998 REM
6999 REM ---- LRS: 3X3 REGIONAL SUMMARY (R/W/P) ----
7000 PRINT
7001 PRINT "LRS  R=ROBOTS W=WRECKS P=PLAYER"
7010 FOR Y=0 TO 2
7020 FOR X=0 TO 2
7030 GOSUB 7100
7031 PRINT " ";K;"/";M;"/";O;
7040 NEXT X
7041 PRINT
7050 NEXT Y
7051 PRINT
7060 RETURN
7098 REM
7099 REM ---- COUNT R/W/P IN REGION (X,Y) -> (K,M,O) ----
7100 LET K=0
7101 LET M=0
7102 LET O=0
7103 LET F=X*3
7104 LET H=Y*3
7110 FOR J=0 TO 2
7120 FOR I=0 TO 2
7130 LET S=(H+J)*9+(F+I)
7131 LET D=PEEK(S)
7132 IF D=2 THEN LET K=K+1
7133 IF D=3 THEN LET M=M+1
7134 IF F+I=A AND H+J=B THEN LET O=1
7140 NEXT I
7150 NEXT J
7160 RETURN
9498 REM
9499 REM ---- GAME END ----
9500 GOSUB 2000
9501 PRINT
9510 IF W=1 THEN PRINT "*** YOU WIN IN ";U;" TURNS! ***"
9520 IF W=0 THEN PRINT "*** YOU WERE CAUGHT. ***"
9530 END
9798 REM
9799 REM ---- RESIGN ----
9800 PRINT
9810 PRINT "*** COMMAND RESIGNED ***"
9820 END
RUN
